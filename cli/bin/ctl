#!/usr/bin/env python3
"""ctl - deterministic fixture-backed CLI for the CLI_VS_SKILLS benchmark."""
import os
import sys

# Make the sibling src/ directory importable regardless of cwd.
_BIN_DIR = os.path.dirname(os.path.abspath(__file__))
_CLI_DIR = os.path.dirname(_BIN_DIR)
sys.path.insert(0, _CLI_DIR)

from src.main import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
